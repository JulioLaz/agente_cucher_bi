# ─── secrets.toml ────────────────────────────────────────────
# Para deploy en Streamlit Cloud:
#   Settings → Secrets → pegar el contenido de este archivo
#
# Para desarrollo local:
#   Crear carpeta .streamlit/ en la raíz del proyecto
#   Guardar este archivo como .streamlit/secrets.toml
#   (NO subir al repositorio — agregar al .gitignore)
# ─────────────────────────────────────────────────────────────

# ── APIs y tokens ─────────────────────────────────────────────
TOKEN_MATHERDUCK    = "tu_token_motherduck_aqui"
key_nvidia          = "tu_api_key_nvidia_aqui"
token_bot_telegram  = "tu_token_bot_telegram_aqui"

# ── Usuarios del sistema ──────────────────────────────────────
[usuarios]
cristina = "vamos_argentina"
horacio  = "vamos_argentina"
julio    = "vamos_argentina"
